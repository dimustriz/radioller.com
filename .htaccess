RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Blazor WASM app at /app/ -> serve from public/app/
RewriteRule ^app$ /app/ [R=301,L]
RewriteRule ^app/(.*) public/app/$1 [L]
RewriteRule ^public/app/ - [L]

# Already in dist - stop
RewriteRule ^dist/ - [L]

# Allow data directory to be served directly
RewriteRule ^data/ - [L]

# Allow data directory to be served directly
RewriteRule ^temp/ - [L]

# Root ? dist/index.html
RewriteRule ^$ /dist/index.html [L]

# Has file extension ? serve file from dist/
RewriteRule ^(.+\..+)$ /dist/$1 [L]

# Trailing slash ? serve index.html from dist/
RewriteRule ^(.+)/$ /dist/$1/index.html [L]

# No extension, no slash ? serve index.html from dist/
RewriteRule ^(.+)$ /dist/$1/index.html [L]
