RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

# Already in dist - stop
RewriteRule ^dist/ - [L]

# Static files: serve directly from dist/
RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
RewriteRule ^(.*)$ /dist/$1 [L]

# Directories: point to index.html directly (avoids mod_dir 301 redirect)
RewriteCond %{DOCUMENT_ROOT}/dist/$1/index.html -f
RewriteRule ^(.+?)/?$ /dist/$1/index.html [L]

# Root URL
RewriteRule ^$ /dist/index.html [L]
