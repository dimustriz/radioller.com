---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, t } from '../i18n/index';

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
---

<Layout title={i.privacy.heading}>
  <section class="page-section">
    <div class="container">
      <div class="page-grid">
        <div class="page-content">
          <h1>{i.privacy.heading}</h1>
          <p class="intro">{i.privacy.intro}</p>
          <ul class="privacy-list">
            {i.privacy.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
        <aside class="page-aside">
          <img src="/undraw_file-search_cbur.svg" alt="" class="aside-illustration" />
        </aside>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-section {
    padding: 6rem 0 4rem;
  }

  .page-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 4rem;
    align-items: start;
  }

  .page-aside {
    position: sticky;
    top: 100px;
  }

  .aside-illustration {
    width: 100%;
    height: auto;
    opacity: 0.85;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 2rem;
    background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .intro {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .privacy-list {
    list-style: none;
  }

  .privacy-list li {
    position: relative;
    padding: 1rem 1.5rem;
    margin-bottom: 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    color: var(--text-muted);
    font-size: 1rem;
    transition: border-color 0.2s;
  }

  .privacy-list li::before {
    content: '\1F6E1';
    margin-right: 0.75rem;
  }

  .privacy-list li:hover {
    border-color: var(--accent);
  }

  @media (max-width: 900px) {
    .page-grid {
      grid-template-columns: 1fr;
    }
    .page-aside { display: none; }
  }

  @media (max-width: 768px) {
    .page-section { padding: 4rem 0 3rem; }
    h1 { font-size: 2rem; }
  }
</style>
