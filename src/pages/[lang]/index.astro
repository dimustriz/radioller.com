---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, t, locales } from '../../i18n/index';

export function getStaticPaths() {
  return locales.filter(l => l !== 'en').map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
const appStoreUrl = 'https://apps.apple.com/us/app/radioller/id6782930257';
---

<Layout>
  <!-- Hero: split layout -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <h1>{i.hero.title}</h1>
        <p class="hero-subtitle">{i.hero.subtitle}</p>
        <a href={appStoreUrl} class="store-badge-link" target="_blank" rel="noopener noreferrer">
          <img src="/app-store-badge.svg" alt="Download on the App Store" class="store-badge" />
        </a>
      </div>
      <div class="hero-visual">
        <img src="/undraw_os-upgrade_ztrf.svg" alt="Radioller app" />
      </div>
    </div>
  </section>

  <!-- How It Works: numbered steps -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">{i.howItWorks.heading}</h2>
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <div class="step-img"><img src="/undraw_podcast_0ioh.svg" alt="" /></div>
          <div class="step-content">
            <h3>{i.howItWorks.liveRadio}</h3>
            <p>{i.howItWorks.liveRadioText}</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <div class="step-img"><img src="/undraw_file-search_cbur.svg" alt="" /></div>
          <div class="step-content">
            <h3>{i.howItWorks.smartSearch}</h3>
            <p>{i.howItWorks.smartSearchText}</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <div class="step-img"><img src="/undraw_listening-to-podcasts_j0hm.svg" alt="" /></div>
          <div class="step-content">
            <h3>{i.howItWorks.playbackControl}</h3>
            <p>{i.howItWorks.playbackControlText}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Streaming: two-column -->
  <section class="section section-alt">
    <div class="container split-section">
      <div class="split-img">
        <img src="/undraw_world_bdnk.svg" alt="Streaming the World" />
      </div>
      <div class="split-text">
        <h2>{i.streaming.heading}</h2>
        <p>{i.streaming.text1}</p>
        <p>{i.streaming.text2}</p>
        <p>{i.streaming.text3}</p>
        <p>{i.streaming.text4}</p>
      </div>
    </div>
  </section>

  <!-- Quote -->
  <section class="section">
    <div class="container">
      <blockquote class="quote">
        <div class="quote-inner">
          <img src="/undraw_pic-profile_nr49.svg" alt={i.streaming.quoteAuthor} class="quote-avatar" />
          <div>
            <p>"{i.streaming.quote}"</p>
            <cite>
              <strong>{i.streaming.quoteAuthor}</strong>
              <span>{i.streaming.quoteRole}</span>
            </cite>
          </div>
        </div>
      </blockquote>
    </div>
  </section>

  <!-- Why Choose Us: feature rows -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">{i.whyChoose.heading}</h2>
      <div class="features">
        <div class="feature">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"/></svg>
          </div>
          <div class="feature-text">
            <h3>{i.whyChoose.freedom}</h3>
            <p>{i.whyChoose.freedomText}</p>
          </div>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <div class="feature-text">
            <h3>{i.whyChoose.discovery}</h3>
            <p>{i.whyChoose.discoveryText}</p>
          </div>
        </div>
        <div class="feature">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="8" cy="12" r="2"/><path d="M16 10v4M14 11v2M18 11v2"/></svg>
          </div>
          <div class="feature-text">
            <h3>{i.whyChoose.control}</h3>
            <p>{i.whyChoose.controlText}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero { padding: 7rem 0 4rem; background: radial-gradient(ellipse at 30% 0%, var(--accent-glow) 0%, transparent 50%); }
  .hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .hero-text h1 { font-size: 3.2rem; font-weight: 800; line-height: 1.1; margin-bottom: 1.2rem; background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero-subtitle { font-size: 1.15rem; color: var(--text-muted); margin-bottom: 2rem; line-height: 1.7; }
  .store-badge-link { display: inline-block; }
  .store-badge { height: 44px; transition: opacity 0.2s, transform 0.2s; }
  .store-badge-link:hover .store-badge { opacity: 0.85; transform: translateY(-2px); }
  .hero-visual { display: flex; justify-content: center; }
  .hero-visual img { max-width: 100%; height: auto; max-height: 380px; filter: drop-shadow(0 12px 32px var(--accent-glow)); }

  .section { padding: 5rem 0; }
  .section-alt { background: var(--bg-card); }
  .section-heading { font-size: 2rem; font-weight: 800; margin-bottom: 3rem; text-align: center; color: var(--text); }

  .steps { display: flex; flex-direction: column; gap: 1.5rem; max-width: 800px; margin: 0 auto; }
  .step { display: grid; grid-template-columns: 48px 120px 1fr; gap: 1.5rem; align-items: center; background: var(--bg-card); border: 1px solid var(--border); border-radius: 20px; padding: 1.5rem 2rem; transition: all 0.3s; }
  .step:hover { border-color: var(--accent); transform: translateX(8px); box-shadow: -4px 4px 24px var(--accent-glow); }
  .step-number { width: 48px; height: 48px; border-radius: 50%; background: var(--accent); color: #1a1412; font-weight: 800; font-size: 1.3rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .step-img img { width: 100%; height: 80px; object-fit: contain; }
  .step-content h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 0.4rem; color: var(--text); }
  .step-content p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; }

  .split-section { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .split-img img { width: 100%; max-height: 350px; object-fit: contain; }
  .split-text h2 { font-size: 2rem; font-weight: 800; margin-bottom: 1.5rem; color: var(--text); }
  .split-text p { color: var(--text-muted); margin-bottom: 1rem; font-size: 1rem; line-height: 1.7; }

  .quote { padding: 2rem; border-left: 4px solid var(--accent); background: var(--quote-bg); border-radius: 0 16px 16px 0; max-width: 800px; margin: 0 auto; }
  .quote-inner { display: flex; gap: 1.5rem; align-items: flex-start; }
  .quote-avatar { width: 80px; height: 80px; flex-shrink: 0; border-radius: 50%; }
  .quote p { font-style: italic; color: var(--text); font-size: 1.1rem; margin-bottom: 1rem; line-height: 1.6; }
  .quote cite { display: flex; flex-direction: column; font-style: normal; }
  .quote cite strong { color: var(--text); font-size: 1rem; }
  .quote cite span { color: var(--text-muted); font-size: 0.9rem; }

  .features { display: flex; flex-direction: column; gap: 1.5rem; max-width: 700px; margin: 0 auto; }
  .feature { display: flex; gap: 1.5rem; align-items: flex-start; padding: 1.5rem 2rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; transition: all 0.3s; }
  .feature:hover { border-color: var(--accent); box-shadow: 0 4px 20px var(--accent-glow); }
  .feature-icon { width: 48px; height: 48px; flex-shrink: 0; background: var(--accent-glow); border-radius: 12px; display: flex; align-items: center; justify-content: center; padding: 10px; }
  .feature-icon svg { width: 28px; height: 28px; color: var(--accent); }
  .feature-text h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.3rem; color: var(--text); }
  .feature-text p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; }

  @media (max-width: 768px) {
    .hero { padding: 5.5rem 0 3rem; }
    .hero-grid { grid-template-columns: 1fr; text-align: center; }
    .hero-text h1 { font-size: 2.4rem; }
    .hero-visual { order: -1; }
    .hero-visual img { max-height: 250px; }
    .step { grid-template-columns: 40px 1fr; gap: 1rem; padding: 1.2rem 1.5rem; }
    .step-img { display: none; }
    .step-number { width: 40px; height: 40px; font-size: 1.1rem; }
    .split-section { grid-template-columns: 1fr; gap: 2rem; }
    .split-img { text-align: center; }
    .split-img img { max-height: 240px; }
    .quote-inner { flex-direction: column; align-items: center; text-align: center; }
    .section { padding: 3.5rem 0; }
    .section-heading { font-size: 1.7rem; }
  }
</style>
