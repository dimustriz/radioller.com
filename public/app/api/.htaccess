# Disable PHP output buffering so proxy.php can stream audio in real-time.
php_flag  output_buffering      off
php_flag  zlib.output_compression off
php_value output_buffering      0

# LiteSpeed: prevent response buffering / connection abort on long-lived responses
<IfModule LiteSpeed>
    RewriteEngine On
    RewriteRule   .* - [E=noabort:1]
</IfModule>

# Tell any upstream reverse proxy (Nginx, Varnish, CDN) not to buffer either
Header always set X-Accel-Buffering "no"
Header always set Cache-Control      "no-cache, no-store, must-revalidate"
